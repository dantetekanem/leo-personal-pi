#!/bin/zsh

set -euo pipefail

current_dir="$(env -u TMUX tmux display-message -p -F '#{pane_current_path}' 2>/dev/null || true)"

if [[ -z "$current_dir" || ! -d "$current_dir" ]]; then
  if [[ -n "${PWD:-}" && "$PWD" != "/" && -d "$PWD" ]]; then
    current_dir="$PWD"
  else
    current_dir="$HOME"
  fi
fi

exec tmux new-session -c "$current_dir"
